<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Smartspacer.Splash.Base" parent="Theme.SplashScreen.IconBackground">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <item name="textAppearanceLargePopupMenu">@style/AppTheme.TextAppearance.Popup</item>
        <item name="postSplashScreenTheme">@style/Theme.Smartspacer</item>
    </style>

    <style name="Theme.Smartspacer.Splash" parent="Theme.Smartspacer.Splash.Base">
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
    </style>

    <style name="Theme.Smartspacer.Transparent" parent="Theme.Material3Expressive.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <style name="Theme.Smartspacer" parent="Theme.Material3Expressive.DayNight.NoActionBar">
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">@bool/lightStatusNav</item>
        <item name="android:windowLightNavigationBar">@bool/lightStatusNav</item>
        <item name="android:overScrollMode">@integer/overscroll_enabled</item>
        <item name="actionOverflowMenuStyle">@style/SmartspacerOverflowMenu</item>
        <item name="popupMenuStyle">@style/SmartspacerOverflowMenu</item>
        <item name="textAppearanceLargePopupMenu">@style/AppTheme.TextAppearance.Popup</item>
    </style>

    <style name="Theme.Smartspacer.Dialog" parent="Theme.Material3Expressive.DayNight.Dialog">
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">@bool/lightStatusNav</item>
        <item name="android:windowLightNavigationBar">@bool/lightStatusNav</item>
        <item name="android:overScrollMode">@integer/overscroll_enabled</item>
        <item name="actionOverflowMenuStyle">@style/SmartspacerOverflowMenu</item>
        <item name="android:popupMenuStyle">@style/SmartspacerOverflowMenu</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>

    <style name="Theme.Smartspacer.Wallpaper" parent="Theme.Material3Expressive.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">@bool/lightStatusNav</item>
        <item name="android:windowLightNavigationBar">@bool/lightStatusNav</item>
        <item name="android:overScrollMode">@integer/overscroll_enabled</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowShowWallpaper">true</item>
        <item name="android:windowAnimationStyle">@style/WallpaperFadeTransition</item>
        <item name="actionOverflowMenuStyle">@style/SmartspacerOverflowMenu</item>
        <item name="popupMenuStyle">@style/SmartspacerOverflowMenu</item>
    </style>

    <style name="Theme.Smartspacer.MinusOne" parent="Theme.Material3Expressive.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">@bool/lightStatusNav</item>
        <item name="android:windowLightNavigationBar">@bool/lightStatusNav</item>
        <item name="android:overScrollMode">@integer/overscroll_enabled</item>
    </style>

    <style name="Theme.Smartspacer.Wallpaper.Light" parent="Theme.Smartspacer.Wallpaper">
        <item name="android:textColorPrimary">@color/expanded_text_color_light</item>
        <item name="materialThemeOverlay">@style/Theme.Smartspacer.Wallpaper.Light.Overlay</item>
    </style>

    <style name="Theme.Smartspacer.Wallpaper.Light.Overlay" parent="Theme.Smartspacer.Wallpaper">
        <item name="android:textColorPrimary">@color/expanded_text_color_light</item>
    </style>

    <style name="Theme.Smartspacer.Wallpaper.Dark" parent="Theme.Smartspacer.Wallpaper">
        <item name="android:textColorPrimary">@color/expanded_text_color_dark</item>
        <item name="materialThemeOverlay">@style/Theme.Smartspacer.Wallpaper.Dark.Overlay</item>
    </style>

    <style name="Theme.Smartspacer.Wallpaper.Dark.Overlay" parent="Theme.Smartspacer.Wallpaper">
        <item name="android:textColorPrimary">@color/expanded_text_color_dark</item>
    </style>

    <style name="SmartspacerOverflowMenu" parent="@style/Widget.Material3.PopupMenu.Overflow">
        <item name="android:popupBackground">@drawable/background_menu</item>
    </style>

    <style name="Theme.MaterialComponents.Light.WhitePrimaryText" parent="Theme.Material3Expressive.Light">
        <item name="android:textColorPrimary">@color/white</item>
    </style>

    <style name="Theme.MaterialComponents.WhitePrimaryText" parent="Theme.Material3Expressive.Dark">
        <item name="android:textColorPrimary">@color/white</item>
    </style>

</resources>