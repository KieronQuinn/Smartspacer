<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Smartspacer.Splash.Base" parent="Theme.SplashScreen.IconBackground">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <item name="textAppearanceLargePopupMenu">@style/AppTheme.TextAppearance.Popup</item>
        <item name="postSplashScreenTheme">@style/Theme.Smartspacer</item>
    </style>

    <style name="Theme.Smartspacer.Splash" parent="Theme.Smartspacer.Splash.Base">
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
    </style>

    <style name="Theme.Smartspacer.Transparent" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <style name="Theme.Smartspacer" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">@bool/lightStatusNav</item>
        <item name="android:windowLightNavigationBar">@bool/lightStatusNav</item>
        <item name="android:overScrollMode">@integer/overscroll_enabled</item>
        <item name="actionOverflowMenuStyle">@style/SmartspacerOverflowMenu</item>
        <item name="textAppearanceLargePopupMenu">@style/AppTheme.TextAppearance.Popup</item>
    </style>

    <style name="Theme.Smartspacer.Dialog" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">@bool/lightStatusNav</item>
        <item name="android:windowLightNavigationBar">@bool/lightStatusNav</item>
        <item name="android:overScrollMode">@integer/overscroll_enabled</item>
        <item name="actionOverflowMenuStyle">@style/SmartspacerOverflowMenu</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <style name="Theme.Smartspacer.Wallpaper" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">@bool/lightStatusNav</item>
        <item name="android:windowLightNavigationBar">@bool/lightStatusNav</item>
        <item name="android:overScrollMode">@integer/overscroll_enabled</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowShowWallpaper">true</item>
        <item name="android:windowAnimationStyle">@style/WallpaperFadeTransition</item>
    </style>

    <style name="Theme.Smartspacer.MinusOne" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">@bool/lightStatusNav</item>
        <item name="android:windowLightNavigationBar">@bool/lightStatusNav</item>
        <item name="android:overScrollMode">@integer/overscroll_enabled</item>
    </style>

    <!-- Light/Dark wallpaper theme variants used by ExpandedFragment/ExpandedAdapter
         to clone the layout inflater context for dark/light theming. -->
    <style name="Theme.Smartspacer.Wallpaper.Light" parent="Theme.Smartspacer.Wallpaper" />
    <style name="Theme.Smartspacer.Wallpaper.Dark" parent="Theme.Smartspacer.Wallpaper" />

    <!-- Overlay applied to the expanded activity when using BLUR or SCRIM background.
         The base theme (Theme.Smartspacer.Wallpaper) already has windowShowWallpaper=true
         and windowBackground=transparent.  This overlay only disables translucency
         (required — setBackgroundBlurRadius() does nothing on translucent windows) and
         suppresses the fade-in animation.
         Parent is ThemeOverlay.AppCompat (intentionally empty — no colour attributes)
         so applyStyle(..., force=true) never overwrites DynamicColors / Monet tokens. -->
    <style name="ThemeOverlay.Smartspacer.BlurWindow" parent="ThemeOverlay.AppCompat">
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <!-- Overlay applied to the expanded activity when using SOLID background.
         The base theme (Theme.Smartspacer.Wallpaper) has windowBackground=transparent
         and windowShowWallpaper=true, which lets the wallpaper bleed through before
         the fragment renders.  This overlay overrides those attributes to make the
         window fully opaque with the Monet colorBackground, hiding the wallpaper
         entirely.
         Parent is ThemeOverlay.AppCompat (no colour attributes) so Monet tokens
         applied by DynamicColors before this overlay are never overwritten. -->
    <style name="ThemeOverlay.Smartspacer.SolidWindow" parent="ThemeOverlay.AppCompat">
        <item name="android:windowBackground">?android:attr/colorBackground</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowShowWallpaper">false</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <style name="AppTheme.ThirdPartyLicences" parent="Theme.MaterialComponents.DayNight">
        <item name="actionBarStyle">@style/ThirdPartyLicencesToolbarTheme</item>
        <item name="android:windowBackground">@color/licenses_background</item>
        <item name="android:statusBarColor">@color/licenses_background</item>
        <item name="android:navigationBarColor">@color/licenses_background</item>
        <item name="android:windowLightStatusBar">@bool/lightStatusNav</item>
        <item name="android:windowLightNavigationBar" tools:ignore="NewApi">@bool/lightStatusNav</item>
        <item name="android:textViewStyle">@style/ThirdPartyLicencesTextViewStyle</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimary</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowAnimationStyle">@style/ThirdPartyLicencesActivityAnimation</item>
    </style>

    <style name="ThirdPartyLicencesActivityAnimation" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

    <style name="ThirdPartyLicencesToolbarTheme" parent="@style/Widget.AppCompat.Light.ActionBar.Solid">
        <item name="background">@color/licenses_toolbar</item>
        <item name="titleTextStyle">@style/ThirdPartyLicencesToolbarTitleStyle</item>
        <item name="colorControlNormal">@android:color/black</item>
        <item name="homeAsUpIndicator">@drawable/ic_back</item>
    </style>

    <style name="ThirdPartyLicencesToolbarTitleStyle" parent="@style/TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@android:color/black</item>
        <item name="android:fontFamily">@font/google_sans_text_medium</item>
    </style>

    <style name="ThirdPartyLicencesTextViewStyle" parent="android:Widget.TextView">
        <item name="android:fontFamily">@font/google_sans_text</item>
    </style>

    <style name="SmartspacerOverflowMenu" parent="@style/Widget.MaterialComponents.PopupMenu.Overflow">
        <item name="android:popupBackground">@drawable/background_menu</item>
    </style>

    <style name="Theme.MaterialComponents.Light.WhitePrimaryText" parent="Theme.MaterialComponents.Light">
        <item name="android:textColorPrimary">@color/white</item>
    </style>

    <style name="Theme.MaterialComponents.WhitePrimaryText" parent="Theme.MaterialComponents">
        <item name="android:textColorPrimary">@color/white</item>
    </style>

</resources>