<?xml version="1.0" encoding="utf-8"?>
<!--
  Material You Expressive settings pane for configuring widget tabs.
  Design language:
    - Large, bold headline (?attr/textAppearanceHeadlineMedium)
    - Tonal colorSurfaceContainer background cards for each tab row
    - Full-color filled FAB (ExtendedFloatingActionButton) to add tabs
    - Filled tonal icon buttons for delete actions
    - Generous padding and rounded corners (ExtraLarge shape)
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true">

    <!-- App bar with large headline title -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/tab_settings_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:fitsSystemWindows="true"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/tab_settings_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="?attr/colorOnSurface"
            app:title="@string/expanded_tab_settings_title"
            app:titleTextAppearance="?attr/textAppearanceTitleLarge"
            app:titleTextColor="?attr/colorOnSurface" />

        <!-- Expressive large headline below the toolbar -->
        <TextView
            android:id="@+id/tab_settings_headline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingTop="8dp"
            android:paddingEnd="24dp"
            android:paddingBottom="8dp"
            android:text="@string/expanded_tab_settings_title"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="?attr/colorOnSurface" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Tab list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tab_settings_recycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="96dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <!-- Empty state — shown when there are no widgets bound yet -->
    <TextView
        android:id="@+id/tab_settings_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="32dp"
        android:text="@string/expanded_tab_settings_no_widgets"
        android:textAppearance="?attr/textAppearanceBodyLarge"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:visibility="gone"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <!-- Add Tab FAB — prominent filled full-color button (Expressive style) -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/tab_settings_add_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:text="@string/expanded_tab_settings_add"
        app:icon="@drawable/ic_fab_add"
        app:backgroundTint="?attr/colorPrimaryContainer"
        app:iconTint="?attr/colorOnPrimaryContainer" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
