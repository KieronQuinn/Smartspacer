<?xml version="1.0" encoding="utf-8"?>
<!--
  Single tab configuration row — Material You Expressive card style.
  Contains an editable label field, a widget-picker button, and a tonal delete button.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Tab number chip — large, colorPrimary tonal surface -->
        <com.google.android.material.chip.Chip
            android:id="@+id/tab_row_index_chip"
            style="@style/Widget.Material3.Chip.Suggestion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:chipBackgroundColor="?attr/colorPrimaryContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:textAppearance="?attr/textAppearanceLabelLarge" />

        <!-- Delete button — tonal, top-end -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/tab_row_delete"
            style="@style/Widget.Material3.Button.TonalButton.Icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/expanded_tab_settings_delete"
            app:icon="@drawable/ic_cross_circle"
            app:iconTint="?attr/colorOnErrorContainer"
            app:backgroundTint="?attr/colorErrorContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Label text field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tab_row_label_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/expanded_tab_settings_label_hint"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tab_row_index_chip">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/tab_row_label_edit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Widget picker button — tonal filled, prominent -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/tab_row_pick_widget"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/expanded_tab_settings_pick_widget"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tab_row_label_layout" />

        <!-- Assigned widget label (shown below picker once a widget is selected) -->
        <TextView
            android:id="@+id/tab_row_widget_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tab_row_pick_widget" />

        <!-- Icon picker button — tonal, shows current icon as button icon when set -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/tab_row_pick_icon"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/expanded_tab_settings_pick_icon"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tab_row_widget_label" />

        <!-- Selected icon name label (shown below icon picker once an icon is chosen) -->
        <TextView
            android:id="@+id/tab_row_icon_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tab_row_pick_icon" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
