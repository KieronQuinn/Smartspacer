<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:transitionGroup="true">

    <!-- App bar holds the M3 Secondary tab strip only. -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/plugin_repository_appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:liftOnScroll="true">

        <!-- M3 Secondary TabLayout: underline indicator, colorPrimary active state,
             no custom pill background. Tabs are set up via TabLayoutMediator. -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/plugin_repository_tabs"
            style="@style/Widget.Material3.TabLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Search box + ViewPager2, positioned below the AppBarLayout. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Search box applies across both pages. -->
        <include
            android:id="@+id/plugin_repository_search"
            layout="@layout/include_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- ViewPager2: swipe between Installed / Available pages. -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/plugin_repository_pager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- Loading overlay shown while data is loading (covers pager). -->
    <LinearLayout
        android:id="@+id/plugin_repository_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/plugin_repository_loading_progress"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            app:trackCornerRadius="4dp"
            app:trackThickness="8dp" />

        <TextView
            android:id="@+id/plugin_repository_loading_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_16"
            android:text="@string/loading"
            android:textAppearance="@style/TextAppearance.AppCompat.Medium.Smartspacer" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
