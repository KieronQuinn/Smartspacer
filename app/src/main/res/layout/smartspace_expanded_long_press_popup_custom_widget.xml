<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:layout_gravity="center_vertical">

    <com.google.android.material.button.MaterialButtonGroup
        style="@style/SmartspacerExpandedPopupButtonGroup"
        android:layout_width="@dimen/smartspace_long_press_popup_width"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="vertical"
        android:theme="@style/Theme.Smartspacer"
        tools:layout_width="wrap_content">

        <com.kieronquinn.app.smartspacer.ui.views.SmartspacerMaterialButton
            android:id="@+id/expanded_long_press_popup_delete"
            style="@style/SmartspacerExpandedPopupButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@android:color/transparent"
            android:gravity="start|center_vertical"
            android:minHeight="@dimen/smartspace_long_press_popup_item_height"
            android:paddingStart="@dimen/smartspace_dismiss_margin"
            android:paddingLeft="@dimen/margin_16"
            android:paddingEnd="@dimen/smartspace_dismiss_margin"
            android:text="@string/expanded_custom_widget_delete"
            android:textAllCaps="false"
            android:textColor="?android:textColorPrimary"
            app:icon="@drawable/ic_delete"
            app:iconPadding="@dimen/margin_16"
            app:iconTint="?android:textColorPrimary" />

        <com.kieronquinn.app.smartspacer.ui.views.SmartspacerMaterialButton
            android:id="@+id/expanded_long_press_popup_options"
            style="@style/SmartspacerExpandedPopupButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@android:color/transparent"
            android:gravity="start|center_vertical"
            android:minHeight="@dimen/smartspace_long_press_popup_item_height"
            android:paddingStart="@dimen/smartspace_dismiss_margin"
            android:paddingLeft="@dimen/margin_16"
            android:paddingEnd="@dimen/smartspace_dismiss_margin"
            android:text="@string/expanded_custom_widget_options"
            android:textAllCaps="false"
            android:textColor="?android:textColorPrimary"
            app:icon="@drawable/ic_settings"
            app:iconPadding="@dimen/margin_16"
            app:iconTint="?android:textColorPrimary" />

        <com.kieronquinn.app.smartspacer.ui.views.SmartspacerMaterialButton
            android:id="@+id/expanded_long_press_popup_rearrange"
            style="@style/SmartspacerExpandedPopupButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@android:color/transparent"
            android:gravity="start|center_vertical"
            android:minHeight="@dimen/smartspace_long_press_popup_item_height"
            android:paddingStart="@dimen/smartspace_dismiss_margin"
            android:paddingLeft="@dimen/margin_16"
            android:paddingEnd="@dimen/smartspace_dismiss_margin"
            android:text="@string/expanded_custom_widget_rearrange"
            android:textAllCaps="false"
            android:textColor="?android:textColorPrimary"
            app:icon="@drawable/ic_expanded_long_press_rearrange"
            app:iconPadding="@dimen/margin_16"
            app:iconTint="?android:textColorPrimary" />

    </com.google.android.material.button.MaterialButtonGroup>
</FrameLayout>