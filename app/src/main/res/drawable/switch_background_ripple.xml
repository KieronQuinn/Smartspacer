        <shape android:shape="rectangle">
            <solid android:color="?android:colorPrimary"/>
        </shape>
        <color android:color="@android:color/white"/>
    </item>
    <item>
        <shape
            android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</ripple>